# 服务配置
BLOG_SERVER_HOST=0.0.0.0
BLOG_SERVER_PORT=8080

# MySQL 配置
BLOG_DB_HOST=127.0.0.1
BLOG_DB_PORT=3306
BLOG_DB_USER=root
BLOG_DB_PASSWORD=123456
BLOG_DB_NAME=blog
BLOG_DB_CHARSET=utf8mb4

# Redis 配置
BLOG_REDIS_HOST=127.0.0.1
BLOG_REDIS_PORT=6379
BLOG_REDIS_PASSWORD=
BLOG_REDIS_DB=0

# JWT 配置
BLOG_JWT_SECRET=your-secret-key-change-in-production
BLOG_JWT_EXPIRE_HOUR=24

# 应用配置
BLOG_UPLOAD_PATH=uploads
BLOG_MAX_UPLOAD_SIZE=10

# 接口限流配置（基于客户端 IP 的固定窗口限流）
BLOG_RATE_LIMIT_ENABLED=true
BLOG_RATE_LIMIT_REQUESTS=100
BLOG_RATE_LIMIT_WINDOW_SEC=60
