# 服务配置
BLOG_SERVER_HOST=0.0.0.0
BLOG_SERVER_PORT=8080

# MySQL 配置
BLOG_DB_HOST=127.0.0.1
BLOG_DB_PORT=3306
BLOG_DB_USER=root
BLOG_DB_PASSWORD=123456
BLOG_DB_NAME=blog
BLOG_DB_CHARSET=utf8mb4

# 只读从库配置（可选），配置后读请求自动路由到从库
# BLOG_DB_REPLICA_HOST=127.0.0.1
# BLOG_DB_REPLICA_PORT=3307
# BLOG_DB_REPLICA_USER=root
# BLOG_DB_REPLICA_PASSWORD=123456

# Redis 配置
BLOG_REDIS_HOST=127.0.0.1
BLOG_REDIS_PORT=6379
BLOG_REDIS_PASSWORD=
BLOG_REDIS_DB=0

# JWT 配置
BLOG_JWT_SECRET=your-secret-key-change-in-production
BLOG_JWT_EXPIRE_HOUR=24

# 应用配置
BLOG_UPLOAD_PATH=uploads
BLOG_MAX_UPLOAD_SIZE=10

# 接口限流配置（基于客户端 IP 的固定窗口限流）
# BLOG_RATE_LIMIT_MODE=redis  # 多实例部署时建议使用 Redis 分布式限流
BLOG_RATE_LIMIT_ENABLED=true
BLOG_RATE_LIMIT_MODE=memory
BLOG_RATE_LIMIT_REQUESTS=100
BLOG_RATE_LIMIT_WINDOW_SEC=60

# SMTP 邮件配置（用于发送邮箱验证码）
BLOG_EMAIL_HOST=smtp.example.com
BLOG_EMAIL_PORT=587
BLOG_EMAIL_USERNAME=noreply@example.com
BLOG_EMAIL_PASSWORD=your-email-password
BLOG_EMAIL_FROM=博客 <noreply@example.com>
BLOG_EMAIL_ENABLE_SSL=true

# 邮箱验证配置
BLOG_EMAIL_VERIFICATION_ENABLED=false
BLOG_EMAIL_VERIFICATION_REQUIRED=false
BLOG_EMAIL_VERIFICATION_CODE_TTL_MIN=30

# 链路追踪配置（OpenTelemetry + OTLP，兼容 Jaeger/Tempo）
BLOG_TRACING_ENABLED=false
BLOG_TRACING_ENDPOINT=http://localhost:4318/v1/traces
BLOG_TRACING_SAMPLE_RATE=1.0
BLOG_TRACING_SERVICE_NAME=blog

# Meilisearch 搜索配置（可选）
BLOG_MEILISEARCH_ENABLED=false
BLOG_MEILISEARCH_HOST=http://localhost:7700
BLOG_MEILISEARCH_API_KEY=
BLOG_MEILISEARCH_INDEX=posts
